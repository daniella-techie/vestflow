# VestFlow Indexer — environment variables
# Copy to .env and fill in values before running.

# Stellar RPC endpoint
RPC_URL=https://soroban-testnet.stellar.org

# VestFlow Soroban contract address
CONTRACT_ID=CCZ6AE75C27DMB3SOIHK7WZSBUG3NQPVLHSVEBQ2FSAEVGRJ5TXAZWCX

# Absolute path to the SQLite database file
# Defaults to vestflow-events.db in the indexer working directory
INDEXER_DB_PATH=./vestflow-events.db

# Polling interval in milliseconds (default: 10 seconds)
POLL_INTERVAL_MS=10000

# Ledger to start from on first run (0 = latest ledger from RPC)
# Set to a specific ledger number to replay history from that point.
START_LEDGER=0

# Port for the query HTTP server
INDEXER_PORT=3001